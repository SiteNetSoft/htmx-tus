{
  "name": "htmx-ext-tus",
  "version": "0.1.0",
  "type": "module",
  "description": "HTMX extension for resumable file uploads via the tus protocol",
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "import": "./dist/htmx-ext-tus.esm.js",
      "default": "./dist/htmx-ext-tus.js"
    }
  },
  "main": "./dist/htmx-ext-tus.js",
  "browser": "./dist/htmx-ext-tus.js",
  "module": "./dist/htmx-ext-tus.esm.js",
  "files": [
    "dist/",
    "LICENSE"
  ],
  "scripts": {
    "build": "node esbuild.config.js",
    "dev": "node esbuild.config.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ test/",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "tus-js-client": "^4.2.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.24.2",
    "eslint": "^10.0.1",
    "htmx.org": "^2.0.4",
    "jsdom": "^25.0.1",
    "vitest": "^3.0.4"
  },
  "peerDependencies": {
    "htmx.org": ">=2.0.0"
  }
}
